def prepare_ml_features(network_results, pca_results, pocket_results, thermo_results):
    """Prepare feature matrix for machine learning"""
    features = []
    labels = []

    for i in range(5):  # 5 sub-trajectories
        sub_traj = f'sub_traj_{i}'

        # Network features
        centrality = network_results[sub_traj]['metrics']['betweenness_centrality']
        avg_centrality = np.mean(list(centrality.values()))

        # PCA features
        pc_variance = pca_results[sub_traj]['cumulative_variance'][:5]  # First 5 PCs

        # Pocket features
        avg_volume = np.mean(pocket_results[sub_traj]['volumes'])
        volume_std = np.std(pocket_results[sub_traj]['volumes'])

        # Thermodynamic features
        entropy = thermo_results[sub_traj]['configurational_entropy']

        # Combine features
        feature_vector = np.concatenate([
            [avg_centrality],
            pc_variance,
            [avg_volume, volume_std],
            [entropy]
        ])

        features.append(feature_vector)
        # Labels would come from experimental resistance data
        labels.append(0)  # Placeholder: 0=sensitive, 1=resistant

    return np.array(features), np.array(labels)

def train_resistance_classifier(features, labels):
    """Train ML models to classify resistance"""
    from sklearn.ensemble import RandomForestClassifier
    from sklearn.svm import SVC
    from sklearn.model_selection import cross_val_score
    from sklearn.preprocessing import StandardScaler

    # Scale features
    scaler = StandardScaler()
    features_scaled = scaler.fit_transform(features)

    # Train multiple models
    models = {
        'RandomForest': RandomForestClassifier(n_estimators=100, random_state=42),
        'SVM': SVC(kernel='rbf', random_state=42),
    }

    results = {}
    for name, model in models.items():
        scores = cross_val_score(model, features_scaled, labels, cv=5)
        model.fit(features_scaled, labels)

        results[name] = {
            'model': model,
            'cv_scores': scores,
            'mean_accuracy': scores.mean(),
            'feature_importance': getattr(model, 'feature_importances_', None)
        }

    return results, scaler

def graph_neural_network_analysis(network_results):
    """Use Graph Neural Networks for residue network analysis"""
    import torch
    from torch_geometric.data import Data
    from torch_geometric.nn import GCNConv

    class ProteinGCN(torch.nn.Module):
        def __init__(self, num_features, hidden_dim=64):
            super().__init__()
            self.conv1 = GCNConv(num_features, hidden_dim)
            self.conv2 = GCNConv(hidden_dim, hidden_dim)
            self.conv3 = GCNConv(hidden_dim, 1)  # Binary classification

        def forward(self, x, edge_index):
            x = torch.relu(self.conv1(x, edge_index))
            x = torch.relu(self.conv2(x, edge_index))
            x = self.conv3(x, edge_index)
            return x

    # Convert network to PyTorch Geometric format
    graph_data = []
    for sub_traj, data in network_results.items():
        # Create node features (e.g., centrality measures)
        centrality = data['metrics']['betweenness_centrality']
        node_features = torch.tensor([[centrality.get(i, 0)] for i in range(len(centrality))],
                                   dtype=torch.float)

        # Create edge index
        edges = [(u, v) for u, v in data['persistent_contacts']]
        edge_index = torch.tensor(edges, dtype=torch.long).t().contiguous()

        graph_data.append(Data(x=node_features, edge_index=edge_index))

    return graph_data